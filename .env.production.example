# Production env template
#
# This is the single canonical production template for both:
# 1) self-hosted Docker Compose
# 2) managed deploys such as Netlify + Northflank + Supabase + Upstash + R2
#
# Keep the same keys for every production target. Only the values change.

# Frontend build env
VITE_API_BASE_URL=https://api.your-domain.example

# Public app
# Self-hosted example:
# APP_BIND_HOST=0.0.0.0
# APP_HTTP_PORT=8080
# PUBLIC_BASE_URL=https://your-domain.example
# FRONTEND_ORIGIN=https://your-domain.example
# FRONTEND_ORIGINS=https://your-domain.example
#
# Managed example:
# PUBLIC_BASE_URL=https://api.your-domain.example
# FRONTEND_ORIGIN=https://app.your-domain.example
# FRONTEND_ORIGINS=https://app.your-domain.example
APP_BIND_HOST=0.0.0.0
APP_HTTP_PORT=8080
PUBLIC_BASE_URL=https://your-domain.example
FRONTEND_ORIGIN=https://your-domain.example
FRONTEND_ORIGINS=https://your-domain.example

# Auth
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-before-deploy
AUTH_COOKIE_NAME=douyin_session
AUTH_SESSION_HOURS=168
AUTH_COOKIE_SECURE=true
AUTH_COOKIE_SAMESITE=none
AUTH_COOKIE_DOMAIN=

# Database and Redis
# Self-hosted example:
# DATABASE_URL=postgresql+psycopg://douyin:change-me-db@postgres:5432/douyin_generator
# REDIS_URL=redis://redis:6379/0
#
# Managed example:
# DATABASE_URL=postgresql+psycopg://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres?sslmode=require
# REDIS_URL=rediss://default:<password>@<region>-<id>.upstash.io:6379
POSTGRES_DB=douyin_generator
POSTGRES_USER=douyin
POSTGRES_PASSWORD=change-me-db
DATABASE_URL=postgresql+psycopg://douyin:change-me-db@postgres:5432/douyin_generator
REDIS_URL=redis://redis:6379/0

# Worker runtime
UVICORN_WORKERS=1
CELERY_WORKER_POOL=threads
CELERY_WORKER_CONCURRENCY=2
CELERY_LOG_LEVEL=info
QUEUE_STALE_JOB_MINUTES=20
QUEUE_CANCELLATION_GRACE_SECONDS=30

# Media tooling
YTDLP_BIN=yt-dlp
YTDLP_COOKIES_FILE=
FFMPEG_BIN=ffmpeg
FFPROBE_BIN=ffprobe
MAX_VIDEO_DURATION_SECONDS=180
MAX_VIDEO_FILE_MB=200
JOB_RETENTION_HOURS=24

# Storage - choose one provider only. Recommended: r2
STORAGE_BACKEND=r2
STORAGE_ROOT=./storage
STORAGE_PREFIX=production
STORAGE_BUCKET=your-r2-bucket
STORAGE_ENDPOINT_URL=https://<account-id>.r2.cloudflarestorage.com
STORAGE_REGION=
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=
STORAGE_SECURE=true
STORAGE_PUBLIC_URL_BASE=
STORAGE_PRESIGN_EXPIRY_SECONDS=3600

# AI providers
STT_PROVIDER=faster_whisper
TRANSLATION_PROVIDER=nine_router
TTS_PROVIDER=fpt_ai

TTS_SAMPLE_RATE=16000
TTS_POLL_ATTEMPTS=20
TTS_POLL_INTERVAL_SECONDS=1.0
VOICE_VOLUME_MULTIPLIER=2.0
MIXED_VOICE_VOLUME_MULTIPLIER=1.0
ORIGINAL_AUDIO_VOLUME_MULTIPLIER=0.18
VOICE_LOUDNORM_TARGET_I=-14.0
VOICE_LOUDNORM_TARGET_TP=-1.5
VOICE_LOUDNORM_TARGET_LRA=11.0

# STT
WHISPER_MODEL=small
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8

# Translation - choose the provider you actually use

# OpenAI
OPENAI_API_KEY=
TRANSLATION_MODEL=gpt-4o-mini
TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe
OPENAI_REQUEST_TIMEOUT_SECONDS=120
OPENAI_TRANSLATION_BATCH_SIZE=20

# Nine Router
NINE_ROUTER_API_KEY=
NINE_ROUTER_MODEL=qwen
NINE_ROUTER_BASE_URL=http://localhost:20128/v1
NINE_ROUTER_REQUEST_TIMEOUT_SECONDS=180
NINE_ROUTER_TRANSLATION_BATCH_SIZE=120

# Groq
GROQ_API_KEY=
GROQ_MODEL=qwen/qwen3-32b
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_REQUEST_TIMEOUT_SECONDS=120
GROQ_TRANSLATION_BATCH_SIZE=10
GROQ_BATCH_SLEEP_SECONDS=15
GROQ_RATE_LIMIT_RETRY_ATTEMPTS=4
GROQ_RATE_LIMIT_SLEEP_SECONDS=20

# OpenRouter
OPENROUTER_API_KEY=
OPENROUTER_MODEL=qwen/qwen3-next-80b-a3b-instruct:free
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_REQUEST_TIMEOUT_SECONDS=120
OPENROUTER_TRANSLATION_BATCH_SIZE=120
OPENROUTER_RATE_LIMIT_RETRY_ATTEMPTS=8
OPENROUTER_RATE_LIMIT_SLEEP_SECONDS=60
OPENROUTER_HTTP_REFERER=
OPENROUTER_APP_TITLE=DouyinGenerator

# Ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:8b
OLLAMA_REQUEST_TIMEOUT_SECONDS=180
OLLAMA_TRANSLATION_BATCH_SIZE=5

# TTS
FPT_AI_API_KEY=
FPT_AI_VOICE_ID=banmai
FPT_AI_SPEED=0
FPT_AI_FORMAT=mp3
FPT_AI_TTS_URL=https://api.fpt.ai/hmi/tts/v5
